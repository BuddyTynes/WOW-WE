#
# Hardcore module config
#

[worldserver]

#
# Enable command-based hardcore mode.
#
Hardcore.Enable = 1

#
# Optional client-known spell aura used as a secondary hardcore marker.
# Keep this disabled by default: many server-side spell auras either do not
# show as a normal unit-frame buff on 3.3.5a clients or have gameplay/visual
# side effects. The old value 21090 is intentionally avoided because it can
# scale players. Use `.hardcore aura test <spellId>` in game to audition
# replacements before changing this on a live group.
#
Hardcore.AuraSpellId = 0

#
# Append this marker to hardcore character names in name-query responses.
# This is intentionally the primary visible marker for this realm because a
# harmless built-in buff icon has not been identified yet. If this value is
# changed or disabled after players have logged in, clear the WoW client Cache
# folder so stale name-query data does not interfere with slash commands,
# friend adds, guild invites, or playerbot commands.
#
Hardcore.NameTag.Enable = 1
Hardcore.NameTag = <HC>

#
# Give random playerbots a one-time chance to become hardcore on first login.
#
Hardcore.RandomBotEnable = 1
Hardcore.RandomBotChance = 100

#
# If enabled, random bots that previously failed their one-time hardcore roll
# are converted to hardcore on future login/map evaluation.
#
Hardcore.RandomBotConvertFailedRolls = 1

#
# Broadcast an on-screen and chat announcement when a hardcore character dies.
#
Hardcore.DeathAnnouncement.Enable = 1

#
# Keep dead hardcore random bots online this long before deleting and
# replacing them through the normal random bot generation/login path. This
# gives the LLM/chat layer a short window to react to the death.
#
Hardcore.BotDeathLogoutDelay = 60

#
# Minimum account security level for `.hardcore bot <name> confirm`.
# 0 = player, 1 = moderator, 2 = gamemaster, 3 = administrator.
#
Hardcore.BotCommandSecurity = 1
