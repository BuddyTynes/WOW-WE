WOW_LLM_BRIDGE_PORT=11434
WOW_LLM_PROVIDER=openai-compatible
WOW_LLM_MODEL=gemma-3n-E2B-it-Q4_K_M
WOW_LLM_BASE_URL=http://host.docker.internal:8088/v1
WOW_LLM_API_KEY=local-llama
WOW_LLM_TIMEOUT_MS=20000
WOW_LLM_BACKEND_HEALTH_TIMEOUT_MS=2000
WOW_LLM_MAX_TOKENS=80
WOW_LLM_MAX_PROMPT_CHARS=8000
WOW_LLM_MAX_OUTPUT_CHARS=800
WOW_LLM_TEMPERATURE=0.8
WOW_LLM_MAX_CONCURRENT=1
WOW_LLM_MAX_QUEUE_SIZE=32
WOW_LLM_MAX_QUEUE_AGE_MS=30000
WOW_LLM_CIRCUIT_FAILURE_THRESHOLD=3
WOW_LLM_CIRCUIT_COOLDOWN_MS=30000

# Gemini direct mode:
# WOW_LLM_PROVIDER=gemini
# WOW_LLM_MODEL=gemini-2.5-flash
# WOW_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# WOW_LLM_API_KEY=put-your-google-key-here

# Hosted OpenAI-compatible mode:
# WOW_LLM_PROVIDER=openai-compatible
# WOW_LLM_MODEL=gpt-5.3-mini
# WOW_LLM_BASE_URL=https://api.openai.com/v1
# WOW_LLM_API_KEY=put-your-key-here
